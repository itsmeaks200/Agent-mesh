# AgentMesh Environment Variables

# Database
DATABASE_URL=postgresql+asyncpg://agentmesh:agentmesh@localhost:5432/agentmesh

# Redis
REDIS_URL=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# Gemini (Phase 6)
# GEMINI_API_KEY=your-api-key-here

# Auth (Phase 8) — leave unset to disable API-key enforcement entirely
# API_KEY=change-me
